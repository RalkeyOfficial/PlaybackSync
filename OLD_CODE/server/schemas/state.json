{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "STATE Message Schema",
  "description": "Schema for STATE message sent by server as authoritative playback state broadcast",
  "required": ["type", "playerState", "videoPos", "server_ts", "eventId"],
  "properties": {
    "type": {
      "type": "string",
      "const": "STATE"
    },
    "playerState": {
      "type": "string",
      "enum": ["playing", "paused"],
      "description": "Current player state. Server state is either 'playing' or 'paused'. Only individual clients can be 'buffering'."
    },
    "videoPos": {
      "type": "number",
      "minimum": 0,
      "description": "Current playback position in seconds"
    },
    "provider": {
      "type": "string",
      "description": "Provider identifier (optional)"
    },
    "episode": {
      "type": "number",
      "description": "Episode number or identifier (optional)"
    },
    "server_ts": {
      "type": "number",
      "description": "Server timestamp (monotonic or epoch ms)"
    },
    "eventId": {
      "type": "number",
      "integer": true,
      "minimum": 0,
      "description": "Event ID for ordering"
    }
  },
  "additionalProperties": false
}
