{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "EPISODE_CHANGE_REQUEST Message Schema",
  "description": "Schema for EPISODE_CHANGE_REQUEST message sent by clients to request episode change",
  "required": ["type", "episodeId", "providerId", "pageUrl", "client_ts"],
  "properties": {
    "type": {
      "type": "string",
      "const": "EPISODE_CHANGE_REQUEST"
    },
    "episodeId": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ],
      "description": "Episode ID or episode number"
    },
    "providerId": {
      "type": "string",
      "minLength": 1,
      "description": "Provider identifier"
    },
    "pageUrl": {
      "type": "string",
      "minLength": 1,
      "description": "Page URL"
    },
    "client_ts": {
      "type": "number",
      "description": "Client timestamp (monotonic or epoch ms)"
    }
  },
  "additionalProperties": false
}
