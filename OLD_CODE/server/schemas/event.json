{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "EVENT Message Schema",
  "description": "Schema for EVENT message sent by clients for explicit control (play, pause, seek)",
  "required": ["type", "event", "client_ts"],
  "properties": {
    "type": {
      "type": "string",
      "const": "EVENT"
    },
    "event": {
      "type": "string",
      "enum": ["play", "pause", "seek"],
      "description": "Event type"
    },
    "value": {
      "type": "number",
      "minimum": 0,
      "description": "Optional value (required for seek events, in seconds)"
    },
    "client_ts": {
      "type": "number",
      "description": "Client timestamp (monotonic or epoch ms)"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": {
      "event": {
        "const": "seek"
      }
    }
  },
  "then": {
    "required": ["value"]
  }
}
