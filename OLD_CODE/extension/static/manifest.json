{
  "manifest_version": 3,
  "name": "PlaybackSync",
  "version": "0.1.0",
  "description": "Synchronize video playback across multiple devices",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.miruro.tv/*",
    "https://www.miruro.to/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.miruro.tv/*",
        "https://www.miruro.to/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
