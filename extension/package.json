{
    "name": "@playbacksync/extension",
    "version": "0.1.0",
    "description": "PlaybackSync browser extension",
    "scripts": {
        "build": "npm run build:background && npm run build:content && npm run build:injected",
        "build:background": "tsc -p tsconfig.background.json",
        "build:content": "tsc -p tsconfig.content.json",
        "build:injected": "tsc -p tsconfig.injected.json",
        "dev": "npm run dev:background & npm run dev:content & npm run dev:injected",
        "dev:background": "tsc -p tsconfig.background.json --watch",
        "dev:content": "tsc -p tsconfig.content.json --watch",
        "dev:injected": "tsc -p tsconfig.injected.json --watch",
        "test": "jest",
        "lint": "eslint src --ext .ts",
        "postbuild": "node copy-static.mjs"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/chrome": "^0.0.258",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "typescript": "^5.3.3"
    }
}