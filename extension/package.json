{
	"name": "@playbacksync/extension",
	"version": "0.1.0",
	"private": true,
	"description": "PlaybackSync browser extension",
	"type": "module",
	"scripts": {
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"compile": "tsc --noEmit",
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"postinstall": "wxt prepare",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"eslint": "^9.13.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.12.0",
		"wxt": "^0.19.0"
	}
}
