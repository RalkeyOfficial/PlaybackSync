{
	"name": "playbacksync",
	"version": "1.0.0",
	"private": true,
	"description": "Synchronized video playback for groups",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"build": "vite --mode production build",
		"build:extension": "npm --prefix extension run build",
		"build:extension:firefox": "npm --prefix extension run build:firefox",
		"dev": "vite --mode development build",
		"dev:extension": "npm --prefix extension run dev",
		"dev:extension:firefox": "npm --prefix extension run dev:firefox",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"stylelint": "stylelint src",
		"stylelint:fix": "stylelint src --fix",
		"test:php": "docker exec -u www-data master-nextcloud-1 sh -c 'cd /var/www/html/apps-extra/playbacksync && phpunit'",
		"test:php:testdox": "docker exec -u www-data master-nextcloud-1 sh -c 'cd /var/www/html/apps-extra/playbacksync && phpunit --testdox'",
		"watch": "vite --mode development build --watch"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"dependencies": {
		"@nextcloud/axios": "2.6.0",
		"@nextcloud/dialogs": "7.3.0",
		"@nextcloud/initial-state": "3.0.0",
		"@nextcloud/l10n": "3.4.1",
		"@nextcloud/logger": "3.0.3",
		"@nextcloud/router": "3.1.0",
		"@nextcloud/vue": "9.8.0",
		"pinia": "3.0.4",
		"vue": "3.5.34",
		"vue-material-design-icons": "5.3.1"
	},
	"devDependencies": {
		"@nextcloud/browserslist-config": "3.1.2",
		"@nextcloud/eslint-config": "9.0.0-rc.9",
		"@nextcloud/stylelint-config": "3.2.2",
		"@nextcloud/vite-config": "2.5.2",
		"@vue/tsconfig": "0.9.1",
		"typescript": "6.0.3",
		"vite": "7.3.3"
	},
	"engines": {
		"node": "^24.0.0",
		"npm": "^11.3.0"
	}
}
