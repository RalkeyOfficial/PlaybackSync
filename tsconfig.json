{
	"extends": "@vue/tsconfig",
	"compilerOptions": {
		"moduleResolution": "Bundler",
		"outDir": "./js/",
		"lib": [
			"DOM",
			"ESNext"
		],
		"types": [
			"vite/client"
		],
		"noImplicitAny": true,
		"allowSyntheticDefaultImports": true
	},
	"exclude": [
		"extension/**",
		"OLD_CODE/**",
		"node_modules/**",
		"js/**"
	]
}
