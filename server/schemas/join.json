{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "JOIN Message Schema",
  "description": "Schema for JOIN message sent by clients to join a room",
  "required": ["type", "roomId", "password", "clientId"],
  "properties": {
    "type": {
      "type": "string",
      "const": "JOIN"
    },
    "roomId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Room identifier (UUID v4)"
    },
    "password": {
      "type": "string",
      "minLength": 1,
      "description": "Room password (plaintext)"
    },
    "clientId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Client identifier (UUID v4)"
    },
    "lastKnownTime": {
      "type": "number",
      "minimum": 0,
      "description": "Last known playback time from client (seconds, optional)"
    }
  },
  "additionalProperties": false
}
