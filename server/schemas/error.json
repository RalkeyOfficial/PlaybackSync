{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "ERROR Message Schema",
  "description": "Schema for ERROR message sent by server for various failure scenarios",
  "required": ["type", "code", "message"],
  "properties": {
    "type": {
      "type": "string",
      "const": "ERROR"
    },
    "code": {
      "type": "string",
      "minLength": 1,
      "description": "Error code (e.g., 'AUTH_FAILED', 'INVALID_MESSAGE', 'RATE_LIMITED')"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable error message"
    },
    "server_ts": {
      "type": "number",
      "description": "Server timestamp (optional)"
    }
  },
  "additionalProperties": false
}
