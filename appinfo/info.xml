<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>playbacksync</id>
	<name>PlaybackSync</name>
	<summary>Synchronized video playback for groups</summary>
	<description><![CDATA[Watch videos in sync with others. Create a room, share the link, and enjoy synchronized playback across all participants.]]></description>
	<version>0.3.0</version>
	<licence>agpl</licence>
	<namespace>PlaybackSync</namespace>
	<category>multimedia</category>

	<bugs>https://github.com/RalkeyOfficial/PlaybackSync/issues</bugs>
	<repository type="git">https://github.com/RalkeyOfficial/PlaybackSync</repository>

	<dependencies>
		<nextcloud min-version="34" max-version="34" />
	</dependencies>

	<background-jobs>
		<job>OCA\PlaybackSync\BackgroundJob\PruneExpiredRoomsJob</job>
	</background-jobs>

	<commands>
		<command>OCA\PlaybackSync\Command\WsServe</command>
	</commands>

	<repair-steps>
		<post-migration>
			<step>OCA\PlaybackSync\Migration\EnsureAdminSecret</step>
		</post-migration>
	</repair-steps>

	<navigations>
		<navigation>
			<name>PlaybackSync</name>
			<route>playbacksync.page.index</route>
			<icon>app.svg</icon>
			<order>50</order>
		</navigation>
	</navigations>

	<settings>
		<admin>OCA\PlaybackSync\Settings\AdminSettings</admin>
		<admin-section>OCA\PlaybackSync\Sections\AdminSection</admin-section>
	</settings>
</info>
